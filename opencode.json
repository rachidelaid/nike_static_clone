{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "Accept": "application/json",
        "X-Goog-Api-Key": "API_KEY"
      }
    },
    "remotion": {
      "type": "local",
      "command": ["npx", "@remotion/mcp@latest"],
      "enabled": true
    }
  }
}
